{
  "name": "Java — Rodar Testes",
  "description": "Após o agente terminar, roda os testes do projeto Java com Maven ou Gradle.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "if [ -f ./mvnw ]; then ./mvnw test -q; elif [ -f ./gradlew ]; then ./gradlew test --quiet; elif command -v mvn &>/dev/null; then mvn test -q; else gradle test --quiet; fi"
  }
}
